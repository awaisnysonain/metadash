{
  "name": "unified-ads-comment-inbox",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=5000 --host=0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "tsx server/dev-all.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "build": "vite build",
    "start": "tsx -e \"process.env.NODE_ENV='production'; import('./server/index.ts')\"",
    "start:prod": "npm run build && tsx -e \"process.env.NODE_ENV='production'; process.env.PORT='5011'; import('./server/index.ts')\"",
    "preview": "vite preview",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "npm run lint:client && npm run lint:server",
    "lint:client": "tsc --noEmit",
    "lint:server": "tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.16.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.15.2",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
