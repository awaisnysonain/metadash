# Frontend (Vite build)
VITE_DEMO_MODE=false
VITE_API_BASE_URL=
VITE_META_WEBHOOK_URL=https://meta-dashboard.nysonik.com/api/meta/webhook

# Server
PORT=5011
NODE_ENV=production
APP_URL=https://meta-dashboard.nysonik.com

# PostgreSQL — password MUST come from environment only (never commit)
DATABASE_URL=postgresql://erp_meta_dashboard:YOUR_PASSWORD@localhost:5432/erp_meta_dashboard

# Meta
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_ACCESS_TOKEN=
META_WEBHOOK_URL=https://meta-dashboard.nysonik.com/api/meta/webhook

# OpenAI comment analysis
OPENAI_API_KEY=
OPENAI_COMMENT_MODEL=gpt-4o-mini
OPENAI_COMMENT_ANALYSIS=true

# Groq AI fallback/primary provider (preferred when configured)
GROQ_API_KEY=
GROQ_COMMENT_MODEL=llama-3.3-70b-versatile
GROQ_REPLY_MODEL=llama-3.3-70b-versatile

# Slack comment alerts
SLACK_BOT_TOKEN=
SLACK_ALERT_CHANNEL_ID=C0B9R8F4V0U
SLACK_ALERTS_ENABLED=true

# Rate-limit-safe comment cron — full coverage every cycle when active ads <= 5000
MAX_COMMENT_SYNC_ADS_PER_RUN=5000
MAX_COMMENT_SYNC_ADS_PER_TOKEN_PER_RUN=5000
COMMENT_SYNC_FULL_COVERAGE=true
COMMENT_SYNC_INTERVAL_MINUTES=10
# Fast high-spend poll — dedicated token lane per brand (FLO / NOBL), skips while full sync runs
COMMENT_SYNC_HIGH_SPEND_POLL=true
COMMENT_SYNC_HIGH_SPEND_INTERVAL_MINUTES=3
COMMENT_SYNC_HIGH_SPEND_ADS_PER_BRAND=15
COMMENT_SYNC_HIGH_SPEND_AD_CONCURRENCY=2
COMMENT_SYNC_HIGH_SPEND_SKIP_DURING_FULL=true
COMMENT_SYNC_AD_CONCURRENCY_PER_TOKEN=8
COMMENT_SYNC_PARALLEL_TOKEN_LANES=true

# Comment retention — permanently delete comments older than this many days (daily cron)
COMMENT_RETENTION_DAYS=30

# Organic comment sweep (non-ad posts on connected FB pages / IG accounts)
COMMENT_SYNC_ORGANIC=true
COMMENT_SYNC_ORGANIC_LOOKBACK_HOURS=72
COMMENT_SYNC_ORGANIC_MEDIA_PER_ACCOUNT=25
# IG organic: only poll brand-owned accounts (not creator/whitelist handles)
COMMENT_SYNC_ORGANIC_IG_BRAND_ONLY=true
COMMENT_SYNC_ORGANIC_IG_BRAND_USERNAMES=nobltravel,myflopilates

# Multi-token lanes (normalize labels to FLO / NOBL)
META_2_LABEL=FLO
META_3_LABEL=NOBL
