# Frontend (Vite build)
VITE_DEMO_MODE=false
VITE_API_BASE_URL=
VITE_META_WEBHOOK_URL=https://meta-dashboard.nysonik.com/api/meta/webhook

# Server
PORT=5011
NODE_ENV=production
APP_URL=https://meta-dashboard.nysonik.com

# PostgreSQL — password MUST come from environment only (never commit)
DATABASE_URL=postgresql://erp_meta_dashboard:YOUR_PASSWORD@localhost:5432/erp_meta_dashboard

# Meta
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_ACCESS_TOKEN=
META_WEBHOOK_URL=https://meta-dashboard.nysonik.com/api/meta/webhook

# OpenAI comment analysis
OPENAI_API_KEY=
OPENAI_COMMENT_MODEL=gpt-4o-mini
OPENAI_COMMENT_ANALYSIS=true

# Slack comment alerts
SLACK_BOT_TOKEN=
SLACK_ALERT_CHANNEL_ID=C0B9R8F4V0U
SLACK_ALERTS_ENABLED=true

# Rate-limit-safe comment cron
MAX_COMMENT_SYNC_ADS_PER_RUN=50
